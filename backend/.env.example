# Copy this file to .env and fill in your own values. Never commit the real .env file.

# Get a key from https://aistudio.google.com/apikey
# If left blank, the app runs fully in MOCK MODE: every Gemini-backed feature
# (recommendation narration, translation, triage) returns a deterministic
# mock response instead of calling the API. This keeps the app runnable and
# demoable out of the box with zero secrets required.
GEMINI_API_KEY=

# Optional: override the Gemini model
GEMINI_MODEL=gemini-2.0-flash

PORT=8787

# Comma-separated list of allowed frontend origins (CORS)
CORS_ORIGIN=http://localhost:5173
