{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^next$|^req$" }],
    "no-console": "off",
    "eqeqeq": "warn",
    "no-var": "error",
    "prefer-const": "warn"
  }
}
